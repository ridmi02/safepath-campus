rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- User profile documents (your original rules) ---
    // If you used capital "Users" in the console:
    match /Users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // This app writes to collection "users" (lowercase) — same rule shape:
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Notification queue (your original rules) ---
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    // --- Companion: virtual walk-home (rooms + published requests) ---
    match /companion_rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;
      allow update, delete: if request.auth != null;

      match /host_ice/{iceId} {
        allow read, write: if request.auth != null;
      }
      match /guest_ice/{iceId} {
        allow read, write: if request.auth != null;
      }
    }

    match /companion_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'open';
      allow update, delete: if request.auth != null;
    }

    // --- Used elsewhere in this app (anonymous auth) ---
    match /incidents/{incidentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /sos_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    // Deny everything else by default (no blanket allow).
  }
}
