rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Voice activation: events (SOS / panic) + per-user panic word doc
    match /voice_activation_events/{eventId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    match /voice_activation/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /Users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tightened self-profile rules:
    // - Student edits own profile only
    // - Student ID and uid are immutable once created
    // - Optional admin override for update/read
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || _isAdmin(database));

      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId;

      allow update: if request.auth != null
        && (
          // Self update with immutable identity fields
          (request.auth.uid == userId
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.sliitId == resource.data.sliitId)
          // Admin update support (for verification workflows)
          || _isAdmin(database)
        );

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Optional profile image document if you later store avatar metadata separately.
    // Example document id = uid, fields: imageUrl, updatedAt.
    match /profile_images/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Optional account delete request queue (if you later move deletes to backend).
    match /account_delete_requests/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    match /companion_rooms/{roomId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;
      allow update, delete: if request.auth != null;

      match /host_ice/{iceId} {
        allow read, write: if request.auth != null;
      }
      match /guest_ice/{iceId} {
        allow read, write: if request.auth != null;
      }
    }

    match /companion_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'open';
      allow update, delete: if request.auth != null;
    }

    match /incidents/{incidentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /sos_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if false;
    }

    function _isAdmin(database) {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
